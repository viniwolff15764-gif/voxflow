{
  "productName": "VoxFlow",
  "version": "0.1.0",
  "identifier": "com.voxflow.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "VoxFlow",
        "width": 350,
        "height": 200,
        "minWidth": 250,
        "minHeight": 120,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "x": 100,
        "y": 100
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      }
    }
  }
}
